# ============================================================
#  AFFiNE Self-Hosted — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit your real .env file to git!
# ============================================================

# ----- AFFiNE -----------------------------------------------
# Use "stable" for latest stable, or pin a specific version tag
# e.g. AFFINE_REVISION=0.25.7
AFFINE_REVISION=stable

# Port the AFFiNE server will listen on inside Docker
PORT=3010

# The full public URL where your AFFiNE instance will be reached.
# Used for e-mail links, OAuth callbacks, etc.
# Example: https://notes.yourdomain.com
AFFINE_SERVER_EXTERNAL_URL=https://affine.yourdomain.com

# A long random string used to sign session cookies.
# Generate one with: openssl rand -hex 32
NODE_OPTIONS=--max-old-space-size=4096
AFFINE_ADMIN_EMAIL=admin@yourdomain.com
AFFINE_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ----- Storage paths ----------------------------------------
# Where uploads and config are persisted on the host.
# Relative paths are relative to the docker-compose.yml location.
UPLOAD_LOCATION=./affine/storage
CONFIG_LOCATION=./affine/config

# ----- PostgreSQL -------------------------------------------
DB_USERNAME=affine
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_DATABASE=affine

# ----- Optional features ------------------------------------
# Enable the search indexer (needs more RAM, ~512 MB extra)
AFFINE_INDEXER_ENABLED=false

# ----- SMTP (optional — for invite e-mails) -----------------
# MAILER_HOST=smtp.yourdomain.com
# MAILER_PORT=465
# MAILER_USER=noreply@yourdomain.com
# MAILER_PASSWORD=CHANGE_ME
# MAILER_SENDER=noreply@yourdomain.com
# MAILER_SECURE=true

# ----- OAuth (optional) -------------------------------------
# GitHub OAuth
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
